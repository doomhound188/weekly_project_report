CW_COMPANY_ID=your_company_id
CW_SITE_URL=api-na.myconnectwise.net
CW_PUBLIC_KEY=your_public_key
CW_PRIVATE_KEY=your_private_key
CW_CLIENT_ID=your_client_id
CW_MEMBER_ID=your_member_id

# AI Provider (configure ONE of the following)
# The app auto-detects which provider to use based on which key is set
# Priority: Anthropic > OpenAI > Gemini (or set AI_PROVIDER explicitly)
AI_PROVIDER=gemini  # Options: gemini, openai, anthropic

# AI Model (optional - uses provider default if not set)
# Defaults: gemini-3-pro-preview, gpt-5.1, claude-sonnet-4-20250514
AI_MODEL=

GOOGLE_API_KEY=your_google_api_key
OPENAI_API_KEY=your_openai_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key

# Microsoft Graph API (for SharePoint + Email)
# Create an App Registration in Azure AD with these permissions:
# - Files.Read.All (Application) - Read SharePoint files
# - Mail.Send (Application) - Send emails
GRAPH_CLIENT_ID=your_azure_app_client_id
GRAPH_CLIENT_SECRET=your_azure_app_client_secret
GRAPH_TENANT_ID=your_azure_tenant_id

# SharePoint Configuration
SHAREPOINT_SITE_NAME=YourSharePointSiteName
SHAREPOINT_FILE_PATH=Project Roadmap 2025.xlsx

# Email Configuration
EMAIL_RECIPIENT=team@yourcompany.com
EMAIL_SENDER=user@yourcompany.com

# Report Configuration
MEMBER_INITIALS=XY

# Web Application (optional - for web interface)
WEB_PORT=5000
WEB_HOST=0.0.0.0
FLASK_SECRET_KEY=change-this-to-a-random-secret-key
FLASK_DEBUG=False
